# Sucu App — environment values
#
# Not: Bu değerler (URL + publishable key) Supabase tasarımı gereği public'tir.
# Güvenlik Row Level Security (RLS) ile sağlanır, key ile değil.
# Kendi Supabase projenizi kullanmak isterseniz .env.local oluşturun ve aşağıdakileri override edin.

EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<publishable-key>
